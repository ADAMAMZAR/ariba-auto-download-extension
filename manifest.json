{
  "manifest_version": 3,
  "name": "GPO - Ariba Automation & NotebookLM Kit",
  "version": "2.0.0",
  "description": "Automatically downloads Ariba attachments into supplier folders and uploads them to NotebookLM. Also includes the NotebookLM Kit: bulk delete, rename, label, and one-click system instruction sync.",
  "permissions": [
    "scripting",
    "downloads",
    "storage",
    "debugger"
  ],
  "host_permissions": [
    "*://*.ariba.com/*",
    "https://notebooklm.google.com/*",
    "https://gist.githubusercontent.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://notebooklm.google.com/*"],
      "js": ["notebooklm_kit.js"],
      "css": ["notebooklm_kit.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["nlm_inject.js"],
      "matches": ["*://notebooklm.google.com/*"]
    }
  ]
}

