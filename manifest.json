{
  "manifest_version": 3,
  "name": "GPO - Automatic Certificate Checker",
  "version": "2.1.0",
  "description": "Automatically expands and downloads attachments from Ariba, saving them in supplier-named folders.",
  "permissions": [
    "scripting",
    "downloads",
    "storage",
    "debugger"
  ],
  "host_permissions": [
    "*://*.ariba.com/*",
    "https://notebooklm.google.com/*",
    "https://gist.githubusercontent.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://notebooklm.google.com/*"
      ],
      "js": [
        "shared/logger.js",
        "shared/constants.js",
        "notebooklm/notebooklm_kit.js"
      ],
      "css": [
        "notebooklm/notebooklm_kit.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "shared/logger.js",
        "notebooklm/nlm_inject.js",
        "shared/constants.js",
        "notebooklm/nlm_runner.js"
      ],
      "matches": [
        "*://notebooklm.google.com/*"
      ]
    },
    {
      "resources": [
        "content/content.css"
      ],
      "matches": [
        "*://*.ariba.com/*"
      ]
    }
  ]
}