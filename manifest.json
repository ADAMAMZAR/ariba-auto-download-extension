{
  "manifest_version": 3,
  "name": "GPO - Automatic Certificate Checker",
  "version": "2.6.21",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "description": "Automatically expands and downloads attachments from Ariba, saving them in supplier-named folders.",
  "permissions": [
    "scripting",
    "downloads",
    "storage",
    "debugger",
    "offscreen",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "*://*.ariba.com/*",
    "https://notebooklm.google.com/*",
    "https://gemini.google.com/*",
    "https://gist.githubusercontent.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "shared/logger.js",
        "shared/constants.js",
        "gemini/gemini_runner.js"
      ],
      "matches": [
        "*://gemini.google.com/*"
      ]
    },
    {
      "resources": [
        "shared/logger.js",
        "notebooklm/nlm_inject.js",
        "shared/constants.js",
        "notebooklm/nlm_runner.js"
      ],
      "matches": [
        "*://notebooklm.google.com/*"
      ]
    },
    {
      "resources": [
        "content/content.css"
      ],
      "matches": [
        "*://*.ariba.com/*"
      ]
    },
    {
      "resources": [
        "pdf_pipeline/*",
        "tessdata/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}